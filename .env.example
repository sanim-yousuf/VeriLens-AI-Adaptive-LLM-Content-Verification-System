APP_ENV=development
LOG_LEVEL=INFO
OPENAI_API_KEY=
OPENAI_TRIAGE_MODEL=gpt-5-nano
OPENAI_STANDARD_MODEL=gpt-5-mini
OPENAI_ADVANCED_MODEL=gpt-5
OPENAI_PREMIUM_MODEL=gpt-5.2
OPENAI_MODERATION_MODEL=omni-moderation-latest
